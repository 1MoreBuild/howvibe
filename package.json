{
  "name": "howvibe",
  "version": "0.1.1",
  "description": "CLI tool to track AI coding tool token usage and costs",
  "type": "module",
  "bin": {
    "howvibe": "dist/index.js"
  },
  "scripts": {
    "postinstall": "patch-package",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "cli",
    "ai",
    "token-usage",
    "claude",
    "codex",
    "cursor",
    "openrouter"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@steipete/sweet-cookie": "^0.1.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "patch-package": "^8.0.1",
    "picocolors": "^1.1.1",
    "tinyglobby": "^0.2.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
